---
import config from 'virtual:config'

import { Icon } from 'astro-pure/user'

const footerConf = config.footer
const social = { ...(footerConf.social || {}) }
const currentYear = new Date().getFullYear()
const startYear = 2024
const displayYear =
  startYear < currentYear ? `${startYear} - ${currentYear}` : String(currentYear)

if (social.email) {
  social.email = {
    ...social.email,
    label: '想和我聊聊吗？给 misswalden@qq.com 发封小邮件吧～',
    url: 'mailto:misswalden@qq.com'
  }
}

// Always expose RSS in the social row.
social.rss = social.rss || {
  label: 'RSS',
  url: '/rss.xml'
}

const footerLink = footerConf.links || []
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='border-t pt-5'>
    <div class='flex items-center gap-y-3 max-md:flex-col md:justify-between md:gap-y-0'>
      <div
        class='flex items-center gap-x-4 gap-y-2 text-muted-foreground max-md:flex-col [&_a]:text-foreground text-sm'
      >
        <div>
          © {displayYear} {config.author}
        </div>
        {
          footerConf.credits && (
            <div>
              <a href='https://github.com/withastro/astro' target='_blank'>
                Astro
              </a>
              &
              <a href='https://github.com/glownight/blog' target='_blank'>
                Pure
              </a>
              theme powered
            </div>
          )
        }
        {
          footerLink.length > 0 && (
            <div class='flex items-center gap-x-2 justify-center'>
              {footerLink.map(({ title, link, style }, index) => (
                <a href={link} target='_blank' class={style}>
                  {title}
                </a>
                <span>{index < footerLink.length - 1 && '|'}</span>
              ))}
            </div>
          )
        }
      </div>

      <div class='flex items-center gap-x-4'>
        {
          Object.entries(social).map(([platform, { label, url }]) => (
            <a
              class='inline-block text-muted-foreground transition-all hover:text-muted-foreground/75'
              href={url}
              aria-label={label}
              title={label}
            >
              <Icon name={platform as keyof typeof social} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
