---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'

// Plugin styles
import 'katex/dist/katex.min.css'

import { MediumZoom } from 'astro-pure/advanced'
import { ArticleBottom, TOC } from 'astro-pure/components/pages'
import Hero from '@/components/pages/Hero.astro'
import Copyright from '@/components/pages/Copyright.astro'
import PageLayout from '@/layouts/ContentLayout.astro'
import { Comment } from '@/components/waline'
import { integ } from '@/site-config'

interface Props {
  post: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}

const {
  post: { id, data },
  posts,
  headings,
  remarkPluginFrontmatter
} = Astro.props

const {
  description,
  heroImage,
  publishDate,
  title,
  updatedDate,
  draft: isDraft,
  comment: enableComment
} = data

const socialImage = heroImage
  ? typeof heroImage.src === 'string'
    ? heroImage.src
    : heroImage.src.src
  : '/images/social-card.png'
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const primaryColor = data.heroImage?.color ?? 'hsl(var(--primary) / var(--un-text-opacity))'

const normalizedHeadings = (() => {
  const valid = headings.filter(
    (heading): heading is MarkdownHeading =>
      Boolean(
        heading &&
          typeof heading.depth === 'number' &&
          typeof heading.slug === 'string' &&
          typeof heading.text === 'string'
      )
  )

  const normalized: MarkdownHeading[] = []
  let hasH2 = false

  for (const heading of valid) {
    if (heading.depth <= 1) continue

    if (!hasH2) {
      normalized.push({
        ...heading,
        depth: 2
      })
      hasH2 = true
      continue
    }

    normalized.push(heading)
  }

  return normalized
})()
---

<PageLayout
  meta={{ articleDate, description, ogImage: socialImage, title }}
  highlightColor={primaryColor}
  back='/blog'
>
  {!!normalizedHeadings.length && <TOC headings={normalizedHeadings} slot='sidebar' />}

  <Hero {data} {remarkPluginFrontmatter} slot='header' />

  <slot />

  <Fragment slot='bottom'>
    {/* Copyright */}
    <Copyright {data} />
    {/* Article recommend */}
    <ArticleBottom collections={posts} {id} class='mt-3 sm:mt-6' />
    {/* Comment */}
    {!isDraft && enableComment && <Comment class='mt-3 sm:mt-6' />}
  </Fragment>

  <slot name='bottom-sidebar' slot='bottom-sidebar' />
</PageLayout>

{integ.mediumZoom.enable && <MediumZoom />}
