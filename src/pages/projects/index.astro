---
import { t } from '@/i18n'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [{ depth: 2, slug: 'projects-overview', text: t('projects.sectionOverview') }]
const projects = [
  {
    name: '个人网站',
    url: 'https://miss.xn--6qq986b3xl'
  },
  {
    name: 'AI智能助手',
    url: 'https://ai.miss.xn--6qq986b3xl'
  }
]
---

<PageLayout title={t('projects.title')} titleI18nKey='projects.title' {headings} view>
  <h2 id='projects-overview' data-i18n='projects.sectionOverview'>{t('projects.sectionOverview')}</h2>
  <p data-i18n='projects.intro'>{t('projects.intro')}</p>
  <div class='mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2'>
    {
      projects.map((project) => (
        <article class='rounded-xl border p-4'>
          <h3 class='m-0 text-lg font-semibold'>{project.name}</h3>
          <p class='mb-3 mt-2 break-all text-muted-foreground'>{project.url}</p>
          <div class='flex gap-3 text-sm'>
            <a
              href={project.url}
              class='inline-flex items-center rounded-lg border px-2.5 py-1 no-underline'
              target='_blank'
              rel='noreferrer'
            >
              访问
            </a>
          </div>
        </article>
      ))
    }
  </div>
</PageLayout>
