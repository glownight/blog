---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, getUniqueTags, sortMDByDate } from '@/utils/blog-server'
import { Button, Icon } from 'astro-pure/user'
import { t } from '@/i18n'
import PaginatorI18n from '@/components/i18n/PaginatorI18n.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  const collections = sortMDByDate(await getBlogCollection())
  const uniqueTags = getUniqueTags(collections)
  const collectionsCount = collections.length
  return paginate(collections, {
    pageSize: config.content.blogPageSize,
    props: { uniqueTags, collectionsCount }
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'blog'>>
  uniqueTags: string[]
  collectionsCount: number
}

const { page, uniqueTags, collectionsCount } = Astro.props

const meta = {
  description: t('blog.metaDescription'),
  title: t('blog.title')
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: t('blog.prevPosts'),
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: t('blog.nextPosts'),
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button
    title={t('common.back')}
    href='/'
    variant='back'
    data-i18n='common.back'
    data-i18n-target='p'
  />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10' data-i18n='blog.title'>{t('blog.title')}</h1>
    </div>
    {
      page.data.length === 0 ? (
        <p data-i18n='common.noPostsYet'>{t('common.noPostsYet')}</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section
            aria-label={t('common.blogPostsList')}
            class='animate'
            id='content'
            data-i18n='common.blogPostsList'
            data-i18n-attr='aria-label'
          >
            {/* header */}
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span
                class='text-muted-foreground'
                data-i18n='blog.pageSummary'
                data-var-current={page.currentPage}
                data-var-shown={page.data.length}
                data-var-total={collectionsCount}
              >
                {t('blog.pageSummary', {
                  current: page.currentPage,
                  shown: page.data.length,
                  total: collectionsCount
                })}
              </span>
              <a
                aria-label={t('blog.viewByYearsAria')}
                href='/archives'
                data-astro-prefetch
                data-i18n='blog.viewByYearsAria'
                data-i18n-attr='aria-label'
              >
                <span data-i18n='blog.viewByYears'>{t('blog.viewByYears')}</span>
              </a>
            </div>
            {/* posts */}
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview {post} detailed />
              ))}
            </ul>
            <PaginatorI18n {...paginationProps} />
          </section>

          {/* sidebar */}
          {!!uniqueTags.length && (
            <aside class='animate' id='sidebar'>
              <h2 class='mb-4 flex items-center text-lg font-semibold'>
                <Icon name='tag-2' class='me-2' />
                <span data-i18n='blog.tagsTitle'>{t('blog.tagsTitle')}</span>
              </h2>
              <ul class='text-bgColor flex flex-wrap gap-2'>
                {uniqueTags.map((tag) => (
                  <li>
                    <Button title={tag} href={`/tags/${tag}`} variant='pill' />
                  </li>
                ))}
              </ul>
              <span class='mt-4 block sm:text-end'>
                <a
                  aria-label={t('blog.viewAllTagsAria')}
                  href='/tags'
                  data-astro-prefetch
                  data-i18n='blog.viewAllTagsAria'
                  data-i18n-attr='aria-label'
                >
                  <span data-i18n='blog.viewAllTags'>{t('blog.viewAllTags')}</span>
                </a>
              </span>
            </aside>
          )}
        </div>
      )
    }
  </main>
</PageLayout>
