---
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, groupCollectionsByYear, sortMDByDate } from '@/utils/blog-server'
import { Button } from 'astro-pure/user'
import { t } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts)
const allPostsByYear = groupCollectionsByYear(allPostsByDate)

const meta = {
  description: t('archives.metaDescription'),
  title: t('archives.title')
}
---

<PageLayout {meta}>
  <Button
    title={t('common.back')}
    href='/blog'
    variant='back'
    data-i18n='common.back'
    data-i18n-target='p'
  />

  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium' data-i18n='archives.title'>{t('archives.title')}</h1>
    </div>

    {allPosts.length === 0 && <p data-i18n='common.noPostsYet'>{t('common.noPostsYet')}</p>}

    <section
      id='content'
      class='animate'
      aria-label={t('common.blogPostsList')}
      data-i18n='common.blogPostsList'
      data-i18n-attr='aria-label'
    >
      {
        allPostsByYear.map(([year, posts]) => (
          <div class='relative mt-20'>
            <h2
              class='absolute -start-6 -top-16 z-0 text-9xl font-bold text-transparent opacity-10'
              style='-webkit-text-stroke-width:2px;-webkit-text-stroke-color:hsl(var(--foreground)/var(--un-text-opacity))'
            >
              <samp>{year}</samp>
            </h2>
            <p class='px-5 text-muted-foreground' data-i18n='archives.postCount' data-var-count={posts.length}>
              {t('archives.postCount', { count: posts.length })}
            </p>
            <ul class='flex flex-col text-start'>
              {posts.map((p) => (
                <PostPreview post={p} class='border-0 bg-transparent py-2' />
              ))}
            </ul>
          </div>
        ))
      }
    </section>
  </main>
</PageLayout>
