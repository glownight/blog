---
import { PFSearch } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import { t } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '@/site-config'

const meta = {
  description: t('search.metaDescription'),
  title: t('search.title')
}
---

<PageLayout {meta}>
  <Button
    title={t('common.back')}
    href='/blog'
    variant='back'
    data-i18n='common.back'
    data-i18n-target='p'
  />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium' data-i18n='search.title'>{t('search.title')}</h1>
    </div>

    <div id='content' class='animate'>
      {
        integ.pagefind ? (
          <>
            <p data-i18n='search.prompt'>{t('search.prompt')}</p>
            <PFSearch />
          </>
        ) : (
          <p data-i18n='search.disabled'>{t('search.disabled')}</p>
        )
      }
    </div>
  </main>
</PageLayout>

