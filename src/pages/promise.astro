---
import { t } from '@/i18n'
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  description: t('promise.metaDescription'),
  title: t('promise.title')
}
---

<PageLayout {meta}>
  <div class='px-4 py-10 text-center sm:px-6 lg:px-8 flex flex-col justify-center items-center h-full'>
    <h1
      class='block text-7xl font-bold sm:text-9xl text-transparent bg-clip-text bg-gradient-to-r from-green-2 to-blue-5'
      data-i18n='promise.title'
    >
      {t('promise.title')}
    </h1>
    <p class='mt-3 text-muted-foreground text-2xl'>
      <span data-i18n='promise.leadPrefix'>{t('promise.leadPrefix')}</span>{' '}
      <span class='text-blue-500 font-bold' data-i18n='promise.leadHighlight'>
        {t('promise.leadHighlight')}
      </span>
    </p>
    <p class='mt-3 text-muted-foreground' data-i18n='promise.classicalQuote'>
      {t('promise.classicalQuote')}
    </p>
    <p class=''>
      <span data-i18n='promise.chasingPrefix'>{t('promise.chasingPrefix')}</span>{' '}
      <span class='text-yellow-500 font-bold' data-i18n='promise.chasingHighlight'>
        {t('promise.chasingHighlight')}
      </span>{' '}
      <span data-i18n='promise.chasingSuffix'>{t('promise.chasingSuffix')}</span>
    </p>
  </div>
</PageLayout>
