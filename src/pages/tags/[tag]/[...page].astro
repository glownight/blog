---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, getUniqueTags, sortMDByDate } from '@/utils/blog-server'
import { Button } from 'astro-pure/user'
import { t } from '@/i18n'
import PaginatorI18n from '@/components/i18n/PaginatorI18n.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getBlogCollection()
  const allPostsByDate = sortMDByDate(allPosts)
  const uniqueTags = getUniqueTags(allPostsByDate)

  return uniqueTags.flatMap((tag) => {
    const filterPosts = allPostsByDate.filter((post) => post.data.tags.includes(tag))
    return paginate(filterPosts, {
      pageSize: config.content.blogPageSize,
      params: { tag }
    })
  })
}

interface Props {
  page: Page<CollectionEntry<'blog'>>
}

const { page } = Astro.props
const { tag } = Astro.params
const safeTag = tag ?? ''

const meta = {
  description: t('tagPosts.metaDescription', { tag: safeTag }),
  title: `${t('tagPosts.titlePrefix')} ${safeTag}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: t('tagPosts.prev'),
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: t('tagPosts.next'),
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button
    title={t('common.back')}
    href='/blog'
    variant='back'
    data-i18n='common.back'
    data-i18n-target='p'
  />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 flex items-end gap-x-2 text-3xl font-medium'>
        <span data-i18n='tagPosts.titlePrefix'>{t('tagPosts.titlePrefix')}</span>
        <span class='text-2xl'>#{safeTag}</span>
      </h1>
    </div>

    <section
      id='content'
      class='animate'
      aria-label={t('common.blogPostsList')}
      data-i18n='common.blogPostsList'
      data-i18n-attr='aria-label'
    >
      <ul class='flex flex-col gap-y-3 text-start'>
        {page.data.map((post) => <PostPreview as='h2' {post} detailed />)}
      </ul>
      <PaginatorI18n {...paginationProps} prevI18nKey='tagPosts.prev' nextI18nKey='tagPosts.next' />
    </section>
  </main>
</PageLayout>
